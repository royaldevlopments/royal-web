# API Base URL for billing backend
# In development, leave empty (uses Vite proxy to localhost:3002)
# In production, set to your backend URL (e.g., Render)
VITE_API_URL=

# Billing client URL (React 19 billing app)
# In development, leave empty (uses /devlopment path via Vite proxy)
# In production, set to the billing app URL (e.g., https://billing.yourdomain.com)
VITE_BILLING_URL=
